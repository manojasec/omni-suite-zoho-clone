model VaultItem {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      VaultFolder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
