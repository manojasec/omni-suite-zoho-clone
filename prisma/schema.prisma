  @@unique([workspaceId, employeeNumber])
  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([workspaceId, departmentId])
}

model LeaveType {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  daysPerYear   Int            @default(0)
  paid          Boolean        @default(true)
  archived      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id              String      @id @default(cuid())
  workspaceId     String
  employeeId      String
  leaveTypeId     String
  status          LeaveStatus @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  days            Decimal     @default(1) @db.Decimal(5, 2)
  reason          String?     @db.Text
  approvedById    String?
  decidedAt       DateTime?
  rejectionReason String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  workspace       Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employee        Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType   @relation(fields: [leaveTypeId], references: [id])

  @@index([workspaceId, status])
  @@index([workspaceId, employeeId])
}

model AttendanceRecord {
  id          String    @id @default(cuid())
  workspaceId String
  employeeId  String
  date        DateTime  @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  hours       Decimal   @default(0) @db.Decimal(5, 2)
  note        String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([workspaceId, date])
}

// ===== E-Signature =====

enum EnvelopeStatus {
  DRAFT
  SENT
  VIEWED
  COMPLETED
  DECLINED
  EXPIRED
  CANCELLED
}

enum SignerStatus {
  PENDING
  SENT
  VIEWED
  SIGNED
  DECLINED
}

model SignatureEnvelope {
  id          String            @id @default(cuid())
  workspaceId String
  createdById String
  title       String
  message     String?           @db.Text
  documentUrl String            @db.Text
  status      EnvelopeStatus    @default(DRAFT)
  expiresAt   DateTime?
  sentAt      DateTime?
  completedAt DateTime?
  cancelledAt DateTime?
  declinedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signers     SignatureSigner[]
  events      SignatureEvent[]

  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
}

model SignatureSigner {
  id              String            @id @default(cuid())
  envelopeId      String
  name            String
  email           String
  order           Int               @default(1)
  status          SignerStatus      @default(PENDING)
  accessToken     String            @unique
  viewedAt        DateTime?
  signedAt        DateTime?
  declinedAt      DateTime?
  declineReason   String?           @db.Text
  signedIp        String?
  signedUserAgent String?           @db.Text
  signatureName   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  envelope        SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  events          SignatureEvent[]

  @@index([envelopeId, order])
  @@index([email])
}

model SignatureEvent {
  id         String            @id @default(cuid())
  envelopeId String
  signerId   String?
  type       String
  ip         String?
  userAgent  String?           @db.Text
  detail     String?           @db.Text
  createdAt  DateTime          @default(now())
  envelope   SignatureEnvelope @relation(fields: [envelopeId], references: [id], onDelete: Cascade)
  signer     SignatureSigner?  @relation(fields: [signerId], references: [id], onDelete: SetNull)

  @@index([envelopeId, createdAt])
}

// ---------------- Bookings (Module 5) ----------------

enum BookingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model BookingType {
  id           String                @id @default(cuid())
  workspaceId  String
  hostId       String
  publicSlug   String                @unique
  name         String
  description  String?               @db.Text
