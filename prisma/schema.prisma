}

model SurveyResponse {
  id          String         @id @default(cuid())
  surveyId    String
  respondent  String?        @db.VarChar(160)
  ip          String?        @db.VarChar(64)
  userAgent   String?        @db.VarChar(500)
  submittedAt DateTime       @default(now())
  survey      Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers     SurveyAnswer[]

  @@index([surveyId, submittedAt])
}

model SurveyAnswer {
  id          String         @id @default(cuid())
  responseId  String
  questionId  String
  text        String?        @db.Text
  number      Float?
  choices     Json           @default("[]")
  createdAt   DateTime       @default(now())
  response    SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@index([responseId])
}

model PivotReport {
  id           String       @id @default(cuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String       @db.VarChar(160)
  description  String?      @db.VarChar(500)
  source       WidgetSource
  rowField     String       @db.VarChar(60)
  colField     String?      @db.VarChar(60)
  valueMetric  WidgetMetric @default(COUNT)
  valueField   String?      @db.VarChar(60)
  rangeDays    Int          @default(30)
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([workspaceId])
}

