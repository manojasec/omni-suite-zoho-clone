// OmniSuite — MVP Prisma schema
// Multi-tenant: every tenant-scoped table includes workspaceId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------------- Identity ----------------

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  name            String?
  hashedPassword  String?
  emailVerified   DateTime?
  image           String?
  twoFactorSecret String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  memberships     Membership[]
  notifications   Notification[]
  ownedContacts   Contact[]      @relation("ContactOwner")
  ownedDeals      Deal[]         @relation("DealOwner")
  assignedTickets Ticket[]       @relation("TicketAssignee")
  assignedTasks   Task[]         @relation("TaskAssignee")
  activities      Activity[]
  sessions        Session[]
  accounts        Account[]
  hostedBookingTypes BookingType[] @relation("BookingTypeHost")
  hostedBookings     Booking[]     @relation("BookingHost")
  reportedIssues     Issue[]        @relation("IssueReporter")
  assignedIssues     Issue[]        @relation("IssueAssignee")
  issueComments      IssueComment[]
  assignedChats      ChatConversation[] @relation("ChatAgent")
  chatMessages       ChatMessage[]      @relation("ChatMessageAgent")
  sentMailMessages   MailMessage[]      @relation("MailSender")
  dashboards         Dashboard[]
  surveys            Survey[]
  pivotReports       PivotReport[]
  notebooks          Notebook[]
  notes              Note[]
  vaultFolders       VaultFolder[]
  vaultItems         VaultItem[]
  vaultAccessLogs    VaultAccessLog[]
  events             Event[]
  teamChannels       TeamChannel[]      @relation("TeamChannelCreator")
  teamChannelMemberships TeamChannelMember[] @relation("TeamChannelMember")
  teamMessages       TeamMessage[]      @relation("TeamMessageAuthor")
  sites              Site[]             @relation("SiteCreator")
  sitePages          SitePage[]         @relation("SitePageEditor")
  socialAccounts     SocialAccount[]    @relation("SocialAccountConnector")
  socialPosts        SocialPost[]       @relation("SocialPostAuthor")
  connectPosts       ConnectPost[]      @relation("ConnectPostAuthor")
  connectComments    ConnectComment[]   @relation("ConnectCommentAuthor")
  connectLikes       ConnectLike[]      @relation("ConnectLikeUser")
  timeEntries        TimeEntry[]        @relation("TimeEntryUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------- Workspace / RBAC ----------------

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SystemRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  AGENT
  SALES
  FINANCE
  VIEWER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Workspace {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  plan                 Plan      @default(FREE)
  currency             String    @default("USD")
  timezone             String    @default("UTC")
  logoUrl              String?
  accentColor          String?   @default("#0F172A")
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String? // active, trialing, past_due, canceled, incomplete, etc.
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships        Membership[]
  invitations        Invitation[]
  contacts           Contact[]
  companies          Company[]
  pipelines          Pipeline[]
  deals              Deal[]
  customers          Customer[]
  invoices           Invoice[]
  quotes             Quote[]
  products           Product[]
  projects           Project[]
  tasks              Task[]
  taskDependencies   TaskDependency[]
  tickets            Ticket[]
  forms              Form[]
  campaigns          Campaign[]
  audiences          Audience[]
  apiKeys            ApiKey[]
  auditLogs          AuditLog[]
  notifications      Notification[]
  activities         Activity[]
  warehouses         Warehouse[]
  inventoryItems     InventoryItem[]
  stockMovements     StockMovement[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  expenseCategories  ExpenseCategory[]
  expenses           Expense[]
  departments        Department[]
  employees          Employee[]
  leaveTypes         LeaveType[]
  leaveRequests      LeaveRequest[]
  attendance         AttendanceRecord[]
  signatureEnvelopes SignatureEnvelope[]
  bookingTypes       BookingType[]
  bookings           Booking[]
  issueProjects      IssueProject[]
  issues             Issue[]
  issueComments      IssueComment[]
  chatConversations  ChatConversation[]
  chatMessages       ChatMessage[]
  workflows          Workflow[]
  workflowEnrollments WorkflowEnrollment[]
  mailThreads        MailThread[]
  mailMessages       MailMessage[]
  ledgerAccounts     LedgerAccount[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]
  bankAccounts       BankAccount[]
  bankTransactions   BankTransaction[]
  jobOpenings        JobOpening[]
  candidates         Candidate[]
  applications       Application[]
  interviews         Interview[]
  folders            Folder[]
  fileAssets         FileAsset[]
  subscriptionPlans  SubscriptionPlan[]
  subscriptions      Subscription[]
  subscriptionInvoices SubscriptionInvoice[]
  dashboards         Dashboard[]
  surveys            Survey[]
  pivotReports       PivotReport[]
  notebooks          Notebook[]
  notes              Note[]
  vaultFolders       VaultFolder[]
  vaultItems         VaultItem[]
  events             Event[]
  teamChannels       TeamChannel[]
  sites              Site[]
  socialAccounts     SocialAccount[]
  socialPosts        SocialPost[]
  connectGroups      ConnectGroup[]
  connectPosts       ConnectPost[]
  leadScoreRules     LeadScoreRule[]
  leadScoreEvents    LeadScoreEvent[]
  experiments        Experiment[]
  courses            Course[]
  payRuns            PayRun[]
  assets             Asset[]
  changes            Change[]
  problems           Problem[]
  storefronts        Storefront[]
  storeCustomers     StoreCustomer[]
  orders             StoreOrder[]
  ssoProviders       SsoProvider[]
  ssoLoginEvents     SsoLoginEvent[]
  heatmapSites       HeatmapSite[]
  flows              Flow[]
  flowRuns           FlowRun[]
  creatorApps        CreatorApp[]
  creatorRecords     CreatorRecord[]
  writerFolders      WriterFolder[]
  writerDocs         WriterDoc[]
  sheets             Sheet[]
  presentations      Presentation[]
  kbCategories       KbCategory[]
  kbArticles         KbArticle[]
  timeEntries        TimeEntry[]
  statusComponents   StatusComponent[]
  statusIncidents    StatusIncident[]
  changelogEntries   ChangelogEntry[]
  roadmapItems       RoadmapItem[]
  roadmapVotes       RoadmapVote[]
}

model Membership {
  id          String           @id @default(cuid())
  userId      String
  workspaceId String
  role        SystemRole       @default(MEMBER)
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Invitation {
  id          String     @id @default(cuid())
  email       String
  workspaceId String
  role        SystemRole @default(MEMBER)
  token       String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model ApiKey {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  hashedKey   String    @unique
  prefix      String
  scopes      Json      @default("[]")
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Notification {
  id          String    @id @default(cuid())
  workspaceId String
  userId      String
  type        String
  title       String
  body        String?
  href        String?
  meta        Json?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, userId, readAt])
}

model AuditLog {
  id          String    @id @default(cuid())
  workspaceId String
  actorId     String?
  action      String
  resource    String
  resourceId  String?
  diff        Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

// ---------------- CRM ----------------

enum LifecycleStage {
  LEAD
  MQL
  SQL
  CUSTOMER
  CHURNED
}

model Company {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  domain      String?
  industry    String?
  size        String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  deals       Deal[]
  customers   Customer[]

  @@index([workspaceId])
}

model Contact {
  id             String         @id @default(cuid())
  workspaceId    String
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  title          String?
  companyId      String?
  ownerId        String?
  lifecycleStage LifecycleStage @default(LEAD)
  source         String?
  tags           Json           @default("[]")
  notes          String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company        Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner          User?          @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities     Activity[]
  deals          Deal[]
  tickets        Ticket[]
  leadScoreEvents LeadScoreEvent[]

  @@index([workspaceId, email])
  @@index([workspaceId, lifecycleStage])
}

enum ActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  TASK
}

model Activity {
  id          String       @id @default(cuid())
  workspaceId String
  type        ActivityType
  subject     String
  body        String?      @db.Text
  contactId   String?
  dealId      String?
  authorId    String?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([workspaceId, contactId])
}

// ---------------- Sales ----------------

model Pipeline {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages      Stage[]
  deals       Deal[]

  @@index([workspaceId])
}

model Stage {
  id          String   @id @default(cuid())
  pipelineId  String
  name        String
  order       Int
  probability Int      @default(0)
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]
}

enum DealStatus {
  OPEN
  WON
  LOST
}

model Deal {
  id              String     @id @default(cuid())
  workspaceId     String
  name            String
  value           Decimal    @default(0) @db.Decimal(14, 2)
  currency        String     @default("USD")
  pipelineId      String
  stageId         String
  status          DealStatus @default(OPEN)
  contactId       String?
  companyId       String?
  ownerId         String?
  expectedCloseAt DateTime?
  wonAt           DateTime?
  lostReason      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline        Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage           Stage      @relation(fields: [stageId], references: [id])
  contact         Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  company         Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner           User?      @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  activities      Activity[]
  invoices        Invoice[]
  quotes          Quote[]

  @@index([workspaceId, stageId])
}

// ---------------- Billing ----------------

model Customer {
  id             String    @id @default(cuid())
  workspaceId    String
  companyId      String?
  name           String
  email          String?
  billingAddress String?   @db.Text
  taxId          String?
  currency       String    @default("USD")
  createdAt      DateTime  @default(now())
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company        Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  invoices       Invoice[]
  quotes         Quote[]
  portalAccesses PortalAccess[]

  @@index([workspaceId])
}

model Product {
  id            String         @id @default(cuid())
  workspaceId   String
  name          String
  sku           String?
  price         Decimal        @default(0) @db.Decimal(14, 2)
  taxPercent    Decimal        @default(0) @db.Decimal(5, 2)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem?
  orderItems    StoreOrderItem[]

  @@index([workspaceId])
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id          String            @id @default(cuid())
  workspaceId String
  number      String
  customerId  String
  dealId      String?
  projectId   String?
  status      InvoiceStatus     @default(DRAFT)
  issueDate   DateTime          @default(now())
  dueDate     DateTime?
  currency    String            @default("USD")
  subtotal    Decimal           @default(0) @db.Decimal(14, 2)
  tax         Decimal           @default(0) @db.Decimal(14, 2)
  total       Decimal           @default(0) @db.Decimal(14, 2)
  balance     Decimal           @default(0) @db.Decimal(14, 2)
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer    Customer          @relation(fields: [customerId], references: [id])
  deal        Deal?             @relation(fields: [dealId], references: [id], onDelete: SetNull)
  project     Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  lineItems   InvoiceLineItem[]
  payments    Payment[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  qty         Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @default(0) @db.Decimal(14, 2)
  taxPercent  Decimal @default(0) @db.Decimal(5, 2)
  amount      Decimal @default(0) @db.Decimal(14, 2)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Decimal  @db.Decimal(14, 2)
  method    String
  reference String?
  paidAt    DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ---------------- Projects ----------------

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

model Project {
  id           String        @id @default(cuid())
  workspaceId  String
  name         String
  description  String?       @db.Text
  status       ProjectStatus @default(PLANNING)
  startDate    DateTime?
  endDate      DateTime?
  budgetHours  Int?
  budgetAmount Decimal?      @db.Decimal(14, 2)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks        Task[]
  invoices     Invoice[]
  timeEntries  TimeEntry[]

  @@index([workspaceId, status])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id           String     @id @default(cuid())
  workspaceId  String
  projectId    String?
  parentTaskId String?
  title        String
  description  String?    @db.Text
  status       TaskStatus @default(TODO)
  priority     Priority   @default(MEDIUM)
  assigneeId   String?
  dueAt        DateTime?
  startAt      DateTime?
  endAt        DateTime?
  progress     Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project      Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Task?      @relation("TaskParent", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]     @relation("TaskParent")
  assignee     User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dependsOn    TaskDependency[] @relation("TaskDependent")
  dependents   TaskDependency[] @relation("TaskPredecessor")
  timeEntries  TimeEntry[]

  @@index([workspaceId, status])
  @@index([workspaceId, projectId])
}

model TaskDependency {
  id            String   @id @default(cuid())
  workspaceId   String
  predecessorId String
  successorId   String
  createdAt     DateTime @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  predecessor   Task     @relation("TaskPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     Task     @relation("TaskDependent", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([successorId, predecessorId])
  @@index([workspaceId, successorId])
  @@index([workspaceId, predecessorId])
}

// ---------------- Helpdesk ----------------

enum TicketStatus {
  OPEN
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
}

model Ticket {
  id                 String          @id @default(cuid())
  workspaceId        String
  number             Int
  subject            String
  description        String?         @db.Text
  status             TicketStatus    @default(OPEN)
  priority           Priority        @default(MEDIUM)
  requesterContactId String?
  assigneeId         String?
  channel            String          @default("web")
  tags               Json            @default("[]")
  firstResponseAt    DateTime?
  resolvedAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requester          Contact?        @relation(fields: [requesterContactId], references: [id], onDelete: SetNull)
  assignee           User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  messages           TicketMessage[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  authorType String // 'agent' | 'contact'
  authorId   String?
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ---------------- Forms ----------------

model Form {
  id          String           @id @default(cuid())
  workspaceId String
  name        String
  publicId    String           @unique @default(cuid())
  schema      Json
  destination String           @default("contact") // contact | lead | ticket | submission
  isPublished Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  payload   Json
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
}

// ---------------- Campaigns ----------------

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model Audience {
  id          String     @id @default(cuid())
  workspaceId String
  name        String
  filterDsl   Json
  createdAt   DateTime   @default(now())
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]
}

model Campaign {
  id          String         @id @default(cuid())
  workspaceId String
  name        String
  audienceId  String?
  subject     String
  html        String         @db.Text
  status      CampaignStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime       @default(now())
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  audience    Audience?      @relation(fields: [audienceId], references: [id], onDelete: SetNull)
}

// ---------------- Inventory ----------------

model Warehouse {
  id          String              @id @default(cuid())
  workspaceId String
  name        String
  code        String?
  address     String?             @db.Text
  isDefault   Boolean             @default(false)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stock       StockLevel[]
  movements   StockMovement[]
  poLines     PurchaseOrderLine[]

  @@index([workspaceId])
}

model InventoryItem {
  id           String              @id @default(cuid())
  workspaceId  String
  productId    String?             @unique
  name         String
  sku          String
  description  String?             @db.Text
  unit         String              @default("each") // each, kg, lb, m, etc.
  costPrice    Decimal             @default(0) @db.Decimal(14, 2)
  salePrice    Decimal             @default(0) @db.Decimal(14, 2)
  reorderPoint Int                 @default(0)
  trackStock   Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product      Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  stock        StockLevel[]
  movements    StockMovement[]
  poLines      PurchaseOrderLine[]

  @@unique([workspaceId, sku])
  @@index([workspaceId])
}

model StockLevel {
  id          String        @id @default(cuid())
  itemId      String
  warehouseId String
  quantity    Int           @default(0)
  updatedAt   DateTime      @updatedAt
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([itemId, warehouseId])
  @@index([warehouseId])
}

enum StockMovementType {
  RECEIVE // PO receipt or manual stock-in
  SHIP // Outgoing (sale, fulfillment)
  ADJUST // Manual correction
  TRANSFER // Between warehouses
}

model StockMovement {
  id          String            @id @default(cuid())
  workspaceId String
  itemId      String
  warehouseId String
  type        StockMovementType
  quantity    Int // signed: + adds, - removes
  reference   String? // PO #, invoice #, etc.
  note        String?           @db.Text
  actorId     String?
  createdAt   DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item        InventoryItem     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([itemId])
}

model Supplier {
  id             String          @id @default(cuid())
  workspaceId    String
  name           String
  email          String?
  phone          String?
  address        String?         @db.Text
  notes          String?         @db.Text
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([workspaceId])
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  workspaceId  String
  number       String
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  currency     String              @default("USD")
  subtotal     Decimal             @default(0) @db.Decimal(14, 2)
  tax          Decimal             @default(0) @db.Decimal(14, 2)
  total        Decimal             @default(0) @db.Decimal(14, 2)
  notes        String?             @db.Text
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  lines        PurchaseOrderLine[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  itemId          String
  warehouseId     String
  description     String
  qtyOrdered      Int           @default(1)
  qtyReceived     Int           @default(0)
  unitCost        Decimal       @default(0) @db.Decimal(14, 2)
  taxPercent      Decimal       @default(0) @db.Decimal(5, 2)
  amount          Decimal       @default(0) @db.Decimal(14, 2)
