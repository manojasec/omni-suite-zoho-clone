enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum EventRegistrationStatus {
  REGISTERED
  CONFIRMED
  ATTENDED
  CANCELLED
  WAITLISTED
}

model Event {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug          String       @db.VarChar(120)
  title         String       @db.VarChar(200)
  summary       String?      @db.VarChar(500)
  description   String?      @db.Text
  location      String?      @db.VarChar(300)
  isVirtual     Boolean      @default(false)
  meetingUrl    String?      @db.VarChar(500)
  status        EventStatus  @default(DRAFT)
  startsAt      DateTime
  endsAt        DateTime
  capacity      Int?
  coverImageUrl String?      @db.VarChar(500)
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      EventSession[]
  registrations EventRegistration[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status, startsAt])
}

model EventSession {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(200)
  speaker   String?  @db.VarChar(160)
  location  String?  @db.VarChar(200)
  startsAt  DateTime
  endsAt    DateTime
  notes     String?  @db.VarChar(1000)
  createdAt DateTime @default(now())

  @@index([eventId, startsAt])
}

model EventRegistration {
  id           String                  @id @default(cuid())
  eventId      String
  event        Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String                  @db.VarChar(160)
  email        String                  @db.VarChar(200)
  phone        String?                 @db.VarChar(40)
  company      String?                 @db.VarChar(200)
  status       EventRegistrationStatus @default(REGISTERED)
  ticketCode   String                  @unique @db.VarChar(40)
  notes        String?                 @db.VarChar(500)
  registeredAt DateTime                @default(now())
  checkedInAt  DateTime?

  @@unique([eventId, email])
  @@index([eventId, status])
}

