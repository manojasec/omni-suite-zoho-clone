  @@index([workspaceId, status])
}

model SurveyQuestion {
  id         String              @id @default(cuid())
  surveyId   String
  position   Int                 @default(0)
  type       SurveyQuestionType  @default(SHORT_TEXT)
  prompt     String              @db.VarChar(500)
