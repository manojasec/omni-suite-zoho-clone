  @@index([workspaceId])
}

model DashboardWidget {
  id          String       @id @default(cuid())
  dashboardId String
  title       String       @db.VarChar(160)
  kind        WidgetKind   @default(KPI)
  source      WidgetSource
  metric      WidgetMetric @default(COUNT)
  metricField String?      @db.VarChar(60)
  groupBy     String?      @db.VarChar(60)
  rangeDays   Int          @default(30)
