// ---------------- Bug Tracker (Module 6) ----------------

enum IssueType {
  BUG
  FEATURE
  TASK
  IMPROVEMENT
}

enum IssuePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum IssueSeverity {
  TRIVIAL
  MINOR
  MAJOR
  CRITICAL
  BLOCKER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
}

model IssueProject {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  name        String
  description String?   @db.Text
  archived    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issues      Issue[]

  @@unique([workspaceId, key])
  @@unique([workspaceId, name])
  @@index([workspaceId, archived])
}

model Issue {
  id              String         @id @default(cuid())
  workspaceId     String
  projectId       String
  number          Int
  title           String
  description     String?        @db.Text
  type            IssueType      @default(BUG)
  priority        IssuePriority  @default(MEDIUM)
  severity        IssueSeverity  @default(MINOR)
  status          IssueStatus    @default(OPEN)
  reporterId      String
  assigneeId      String?
  environment     String?
  stepsToReproduce String?       @db.Text
  expected        String?        @db.Text
  actual          String?        @db.Text
  version         String?
  dueDate         DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  tags            String? // comma-separated, MVP only
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         IssueProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporter        User           @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  assignee        User?          @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments        IssueComment[]

  @@unique([projectId, number])
  @@index([workspaceId, status])
  @@index([workspaceId, assigneeId])
  @@index([projectId, status, priority])
}

model IssueComment {
  id          String    @id @default(cuid())
  workspaceId String
  issueId     String
  authorId    String
  body        String    @db.Text
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  issue       Issue     @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([issueId, createdAt])
}

// ---------------- Live Chat ----------------

enum ChatStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

enum ChatSender {
  VISITOR
  AGENT
  SYSTEM
}

model ChatConversation {
  id          String     @id @default(cuid())
  workspaceId String
  publicId    String     @unique @default(cuid())
  visitorName String?
  visitorEmail String?
  pageUrl     String?
  userAgent   String?    @db.Text
  status      ChatStatus @default(OPEN)
  agentId     String?
  lastMessageAt DateTime @default(now())
  resolvedAt  DateTime?
  closedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent       User?      @relation("ChatAgent", fields: [agentId], references: [id], onDelete: SetNull)
  messages    ChatMessage[]

  @@index([workspaceId, status])
  @@index([workspaceId, lastMessageAt])
}

model ChatMessage {
  id             String           @id @default(cuid())
  workspaceId    String
  conversationId String
  sender         ChatSender
  agentId        String?
  body           String           @db.Text
  createdAt      DateTime         @default(now())

  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
