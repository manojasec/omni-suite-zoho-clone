  DRAFT
  PUBLISHED
}

enum ChangelogEntryType {
  FEATURE
  IMPROVEMENT
  FIX
  ANNOUNCEMENT
}

model ChangelogEntry {
  id          String               @id @default(cuid())
  workspaceId String
  title       String                @db.VarChar(200)
  slug        String                @db.VarChar(200)
  excerpt     String?               @db.VarChar(500)
  body        String                @db.LongText
