  id          String             @id @default(cuid())
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)
  ruleId      String?
  rule        LeadScoreRule?     @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  eventType   LeadScoreEventType
  points      Int
  reason      String?            @db.VarChar(300)
  createdAt   DateTime           @default(now())

  @@index([workspaceId, contactId, createdAt])
}

// ---------------- A/B Experiments (PageSense) ----------------

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum ExperimentEventKind {
  VIEW
  CONVERSION
}

model Experiment {
  id            String                  @id @default(cuid())
  workspaceId   String
  workspace     Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug          String                  @db.VarChar(80)
  name          String                  @db.VarChar(160)
  hypothesis    String?                 @db.VarChar(1000)
  primaryMetric String?                 @db.VarChar(120)
  status        ExperimentStatus        @default(DRAFT)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  variants      ExperimentVariant[]
  assignments   ExperimentAssignment[]
  events        ExperimentEvent[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model ExperimentVariant {
  id           String      @id @default(cuid())
  experimentId String
  experiment   Experiment  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  key          String      @db.VarChar(40)
  label        String      @db.VarChar(120)
  weight       Int         @default(50)
  isControl    Boolean     @default(false)

  @@unique([experimentId, key])
}

model ExperimentAssignment {
  id           String      @id @default(cuid())
  experimentId String
  experiment   Experiment  @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  visitorId    String      @db.VarChar(64)
  variantKey   String      @db.VarChar(40)
  assignedAt   DateTime    @default(now())

  @@unique([experimentId, visitorId])
  @@index([experimentId, variantKey])
}

model ExperimentEvent {
  id           String              @id @default(cuid())
  experimentId String
  experiment   Experiment          @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variantKey   String              @db.VarChar(40)
  visitorId    String              @db.VarChar(64)
  kind         ExperimentEventKind
  value        Decimal?            @db.Decimal(14, 2)
  occurredAt   DateTime            @default(now())

  @@index([experimentId, variantKey, kind])
  @@index([experimentId, occurredAt])
}

// ===== Module 27: Learn (LMS) =====

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseEnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
}

model Course {
  id            String       @id @default(cuid())
  workspaceId   String
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug          String       @db.VarChar(80)
  title         String       @db.VarChar(160)
  summary       String?      @db.VarChar(500)
  description   String?      @db.Text
  status        CourseStatus @default(DRAFT)
  coverImageUrl String?      @db.VarChar(500)
  createdById   String
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  lessons       Lesson[]
  enrollments   CourseEnrollment[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model Lesson {
  id              String   @id @default(cuid())
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  position        Int      @default(0)
  title           String   @db.VarChar(200)
  content         String?  @db.Text
  durationMinutes Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  progress        LessonProgress[]

  @@unique([courseId, position])
  @@index([courseId])
}

model CourseEnrollment {
  id           String                 @id @default(cuid())
  courseId     String
  course       Course                 @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learnerEmail String                 @db.VarChar(200)
  learnerName  String                 @db.VarChar(160)
  status       CourseEnrollmentStatus @default(ENROLLED)
  enrolledAt   DateTime               @default(now())
  completedAt  DateTime?
  progress     LessonProgress[]

  @@unique([courseId, learnerEmail])
  @@index([courseId, status])
}

model LessonProgress {
  id           String           @id @default(cuid())
  enrollmentId String
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lessonId     String
  lesson       Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt  DateTime         @default(now())

  @@unique([enrollmentId, lessonId])
  @@index([lessonId])
}

// ===== Module 28: Payroll =====

enum PayRunStatus {
  DRAFT
  APPROVED
  PAID
  CANCELED
}

enum PayItemKind {
  EARNING
  DEDUCTION
  TAX
}

model PayRun {
  id               String       @id @default(cuid())
  workspaceId      String
  workspace        Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  label            String       @db.VarChar(160)
  periodStart      DateTime     @db.Date
  periodEnd        DateTime     @db.Date
  payDate          DateTime     @db.Date
  currency         String       @default("USD") @db.Char(3)
  status           PayRunStatus @default(DRAFT)
  totalGross       Decimal      @default(0) @db.Decimal(14, 2)
  totalDeductions  Decimal      @default(0) @db.Decimal(14, 2)
  totalTax         Decimal      @default(0) @db.Decimal(14, 2)
  totalNet         Decimal      @default(0) @db.Decimal(14, 2)
  notes            String?      @db.VarChar(1000)
  createdById      String
  approvedAt       DateTime?
  paidAt           DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  slips            PaySlip[]

  @@index([workspaceId, status])
  @@index([workspaceId, payDate])
}

model PaySlip {
  id            String        @id @default(cuid())
  payRunId      String
  payRun        PayRun        @relation(fields: [payRunId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  gross         Decimal       @default(0) @db.Decimal(14, 2)
  deductions    Decimal       @default(0) @db.Decimal(14, 2)
  tax           Decimal       @default(0) @db.Decimal(14, 2)
  net           Decimal       @default(0) @db.Decimal(14, 2)
  notes         String?       @db.VarChar(500)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  items         PaySlipItem[]

  @@unique([payRunId, employeeId])
  @@index([employeeId])
}

model PaySlipItem {
  id        String      @id @default(cuid())
  paySlipId String
  paySlip   PaySlip     @relation(fields: [paySlipId], references: [id], onDelete: Cascade)
  kind      PayItemKind
  label     String      @db.VarChar(120)
  amount    Decimal     @db.Decimal(14, 2)
  createdAt DateTime    @default(now())

  @@index([paySlipId, kind])
}

// ---------------- ITSM (Assets / Changes / Problems) ----------------

enum AssetStatus {
  IN_USE
  IN_STORAGE
  RETIRED
  LOST
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELED
}

enum ChangeRisk {
  LOW
  MEDIUM
  HIGH
}

enum ProblemStatus {
  OPEN
  INVESTIGATING
  KNOWN_ERROR
  RESOLVED
  CLOSED
}

model Asset {
  id                   String      @id @default(cuid())
  workspaceId          String
  workspace            Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tag                  String      @db.VarChar(60)
  name                 String      @db.VarChar(160)
  category             String      @default("general") @db.VarChar(60)
  status               AssetStatus @default(IN_USE)
  serial               String?     @db.VarChar(120)
  vendor               String?     @db.VarChar(120)
  location             String?     @db.VarChar(160)
  assignedToEmployeeId String?
  assignedTo           Employee?   @relation("AssetAssignee", fields: [assignedToEmployeeId], references: [id], onDelete: SetNull)
  purchaseDate         DateTime?   @db.Date
  cost                 Decimal?    @db.Decimal(12, 2)
  notes                String?     @db.VarChar(1000)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  changes              Change[]
  problems             Problem[]

  @@unique([workspaceId, tag])
  @@index([workspaceId, status])
  @@index([assignedToEmployeeId])
}

model Change {
  id           String       @id @default(cuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number       Int
  title        String       @db.VarChar(200)
  description  String?      @db.Text
  status       ChangeStatus @default(DRAFT)
  risk         ChangeRisk   @default(MEDIUM)
  assetId      String?
  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  requestedById String
  approvedAt   DateTime?
  scheduledAt  DateTime?
  completedAt  DateTime?
  rollbackPlan String?      @db.VarChar(2000)
  notes        String?      @db.VarChar(2000)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
  @@index([assetId])
}

model Problem {
  id          String        @id @default(cuid())
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number      Int
  title       String        @db.VarChar(200)
  description String?       @db.Text
  status      ProblemStatus @default(OPEN)
  priority    Priority      @default(MEDIUM)
  assetId     String?
  asset       Asset?        @relation(fields: [assetId], references: [id], onDelete: SetNull)
  rootCause   String?       @db.VarChar(2000)
  workaround  String?       @db.VarChar(2000)
  resolution  String?       @db.VarChar(2000)
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
  @@index([assetId])
}

// ---------------- Commerce / Storefront ----------------

enum StorefrontStatus {
  DRAFT
  PUBLISHED
}

enum StoreOrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELED
  REFUNDED
}

model Storefront {
  id            String           @id @default(cuid())
  workspaceId   String
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug          String           @unique
  name          String           @db.VarChar(160)
  headline      String?          @db.VarChar(240)
  currency      String           @default("USD") @db.Char(3)
  supportEmail  String?          @db.VarChar(160)
  status        StorefrontStatus @default(DRAFT)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([workspaceId])
}

model StoreCustomer {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email       String       @db.VarChar(160)
  name        String       @db.VarChar(160)
  phone       String?      @db.VarChar(60)
  shippingAddress String?  @db.VarChar(1000)
  notes       String?      @db.VarChar(1000)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  orders      StoreOrder[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
}

model StoreOrder {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  number      Int
  customerId  String
  customer    StoreCustomer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status      StoreOrderStatus @default(PENDING)
  currency    String           @default("USD") @db.Char(3)
  subtotal    Decimal          @default(0) @db.Decimal(14, 2)
  tax         Decimal          @default(0) @db.Decimal(14, 2)
  total       Decimal          @default(0) @db.Decimal(14, 2)
  notes       String?          @db.VarChar(2000)
  paidAt      DateTime?
  fulfilledAt DateTime?
  canceledAt  DateTime?
  refundedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  items       StoreOrderItem[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
  @@index([customerId])
}

model StoreOrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  nameSnapshot String    @db.VarChar(200)
  quantity    Int        @default(1)
  unitPrice   Decimal    @db.Decimal(14, 2)
  taxPercent  Decimal    @default(0) @db.Decimal(5, 2)
  lineSubtotal Decimal   @default(0) @db.Decimal(14, 2)
  lineTax     Decimal    @default(0) @db.Decimal(14, 2)
  lineTotal   Decimal    @default(0) @db.Decimal(14, 2)
  createdAt   DateTime   @default(now())

  @@unique([orderId, productId])
  @@index([orderId])
}

// ---------------- OneAuth / SAML SSO ----------------

enum SsoProtocol {
  SAML
  OIDC
}

enum SsoProviderStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum SsoLoginKind {
  LOGIN_SUCCESS
  LOGIN_FAILED
  PROVISION
}

model SsoProvider {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String            @db.VarChar(160)
  protocol    SsoProtocol       @default(SAML)
  status      SsoProviderStatus @default(DRAFT)
  domain      String?           @db.VarChar(160)
  entityId    String            @db.VarChar(400)
  ssoUrl      String            @db.VarChar(600)
  sloUrl      String?           @db.VarChar(600)
  certificate String?           @db.Text
  emailAttr   String            @default("email") @db.VarChar(80)
  nameAttr    String            @default("name") @db.VarChar(80)
  defaultRole SystemRole        @default(MEMBER)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  events      SsoLoginEvent[]

  @@unique([workspaceId, name])
  @@unique([workspaceId, domain])
  @@index([workspaceId, status])
}

model SsoLoginEvent {
  id          String       @id @default(cuid())
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  providerId  String
  provider    SsoProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  email       String       @db.VarChar(160)
  kind        SsoLoginKind
  reason      String?      @db.VarChar(400)
  ipAddress   String?      @db.VarChar(64)
  userAgent   String?      @db.VarChar(400)
  occurredAt  DateTime     @default(now())

  @@index([workspaceId, occurredAt])
  @@index([providerId, occurredAt])
}

// ---------------- Heatmaps / Session recordings ----------------

enum HeatmapSiteStatus {
  ACTIVE
  PAUSED
}

enum HeatmapEventKind {
  CLICK
  MOVE
  SCROLL
}

enum SessionRecordingStatus {
  RECORDING
  COMPLETED
  ARCHIVED
}

model HeatmapSite {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String              @db.VarChar(160)
  domain      String              @db.VarChar(160)
  trackerKey  String              @unique @db.VarChar(40)
  status      HeatmapSiteStatus   @default(ACTIVE)
  sampleRate  Int                 @default(100)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  pages       HeatmapPage[]
  events      HeatmapEvent[]
  recordings  SessionRecording[]

  @@unique([workspaceId, domain])
  @@index([workspaceId, status])
}

model HeatmapPage {
  id          String         @id @default(cuid())
  siteId      String
  site        HeatmapSite    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  path        String         @db.VarChar(400)
  label       String?        @db.VarChar(160)
  viewCount   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  events      HeatmapEvent[]

  @@unique([siteId, path])
  @@index([siteId])
}

model HeatmapEvent {
  id         String           @id @default(cuid())
  siteId     String
  site       HeatmapSite      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pageId     String
  page       HeatmapPage      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  kind       HeatmapEventKind
  xPercent   Decimal          @db.Decimal(6, 3)
  yPercent   Decimal          @db.Decimal(6, 3)
  viewport   Int?
  selector   String?          @db.VarChar(400)
  occurredAt DateTime         @default(now())

  @@index([pageId, kind])
  @@index([siteId, occurredAt])
}

model SessionRecording {
  id           String                 @id @default(cuid())
  siteId       String
  site         HeatmapSite            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  visitorId    String                 @db.VarChar(64)
  status       SessionRecordingStatus @default(RECORDING)
  startedAt    DateTime               @default(now())
  endedAt      DateTime?
  durationMs   Int                    @default(0)
  pageCount    Int                    @default(0)
  eventCount   Int                    @default(0)
  startUrl     String                 @db.VarChar(600)
  userAgent    String?                @db.VarChar(400)
  ipAddress    String?                @db.VarChar(64)
  events       SessionEvent[]

  @@index([siteId, startedAt])
  @@index([siteId, status])
}

model SessionEvent {
  id           String           @id @default(cuid())
  recordingId  String
  recording    SessionRecording @relation(fields: [recordingId], references: [id], onDelete: Cascade)
  offsetMs     Int
  kind         String           @db.VarChar(40)
  payload      Json?
  occurredAt   DateTime         @default(now())

  @@index([recordingId, offsetMs])
}

// ---------------- Command Center (Flows) ----------------

enum FlowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum FlowTrigger {
  MANUAL
  WEBHOOK
  SCHEDULE
}

enum FlowNodeKind {
  START
  TASK
  CONDITION
  APPROVAL
  WEBHOOK_CALL
  DELAY
  END
}

enum FlowRunStatus {
  PENDING
  RUNNING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELED
}

enum FlowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  SKIPPED
  FAILED
}

enum FlowApprovalDecision {
  PENDING
  APPROVED
  REJECTED
}

model Flow {
  id          String      @id @default(cuid())
  workspaceId String
  name        String      @db.VarChar(160)
  description String?     @db.VarChar(500)
  status      FlowStatus  @default(DRAFT)
  trigger     FlowTrigger @default(MANUAL)
  version     Int         @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  nodes       FlowNode[]
  edges       FlowEdge[]
  runs        FlowRun[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
}

model FlowNode {
  id         String       @id @default(cuid())
  flowId     String
  key        String       @db.VarChar(64)
  kind       FlowNodeKind
  label      String       @db.VarChar(160)
  config     Json?
  posX       Int          @default(0)
  posY       Int          @default(0)

  flow       Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([flowId, key])
  @@index([flowId])
}

model FlowEdge {
  id      String  @id @default(cuid())
  flowId  String
  fromKey String  @db.VarChar(64)
  toKey   String  @db.VarChar(64)
  branch  String? @db.VarChar(40)

  flow    Flow    @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([flowId, fromKey])
}

model FlowRun {
  id             String        @id @default(cuid())
  flowId         String
  workspaceId    String
  status         FlowRunStatus @default(PENDING)
  currentNodeKey String?       @db.VarChar(64)
  triggeredById  String?
  input          Json?
  output         Json?
  error          String?       @db.VarChar(600)
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?

  flow           Flow          @relation(fields: [flowId], references: [id], onDelete: Cascade)
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  steps          FlowRunStep[]

  @@index([workspaceId, status])
  @@index([flowId, startedAt])
}

model FlowRunStep {
  id               String                @id @default(cuid())
  runId            String
  nodeKey          String                @db.VarChar(64)
  kind             FlowNodeKind
  status           FlowStepStatus        @default(PENDING)
  approvalDecision FlowApprovalDecision?
  approverId       String?
  decidedAt        DateTime?
  comment          String?               @db.VarChar(500)
  output           Json?
  note             String?               @db.VarChar(500)
  startedAt        DateTime              @default(now())
  finishedAt       DateTime?

  run              FlowRun               @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, startedAt])
  @@index([runId, status])
}

// ---------------- AppCreator (low-code) ----------------

enum CreatorAppStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CreatorFieldKind {
  TEXT
  TEXTAREA
  NUMBER
  DATE
  BOOLEAN
  SELECT
  EMAIL
  URL
}

model CreatorApp {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String           @db.VarChar(160)
  slug        String           @db.VarChar(80)
  description String?          @db.VarChar(500)
  icon        String?          @db.VarChar(40)
  status      CreatorAppStatus @default(DRAFT)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  entities    CreatorEntity[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model CreatorEntity {
  id          String          @id @default(cuid())
  appId       String
  app         CreatorApp      @relation(fields: [appId], references: [id], onDelete: Cascade)
  key         String          @db.VarChar(64)
  label       String          @db.VarChar(160)
  description String?         @db.VarChar(500)
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  fields      CreatorField[]
  records     CreatorRecord[]

  @@unique([appId, key])
  @@index([appId])
}

model CreatorField {
  id        String           @id @default(cuid())
  entityId  String
  entity    CreatorEntity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  key       String           @db.VarChar(64)
  label     String           @db.VarChar(160)
  kind      CreatorFieldKind
  required  Boolean          @default(false)
  helpText  String?          @db.VarChar(300)
  options   Json?
  position  Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([entityId, key])
  @@index([entityId])
}

model CreatorRecord {
  id          String        @id @default(cuid())
  entityId    String
  entity      CreatorEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  data        Json
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([entityId, createdAt])
  @@index([workspaceId])
}


// ---------------- Writer (collaborative docs) ----------------

enum WriterDocStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum WriterDocVisibility {
  PRIVATE
  WORKSPACE
  PUBLIC
}

model WriterFolder {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      WriterFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    WriterFolder[] @relation("FolderTree")
  name        String         @db.VarChar(160)
  position    Int            @default(0)
  docs        WriterDoc[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([workspaceId, parentId])
}

model WriterDoc {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      WriterFolder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  title       String              @db.VarChar(200)
  content     String              @db.LongText
  status      WriterDocStatus     @default(DRAFT)
  visibility  WriterDocVisibility @default(WORKSPACE)
  authorId    String?
  wordCount   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  versions    WriterDocVersion[]

  @@index([workspaceId, status])
  @@index([workspaceId, folderId])
}

model WriterDocVersion {
  id        String    @id @default(cuid())
  docId     String
  doc       WriterDoc @relation(fields: [docId], references: [id], onDelete: Cascade)
  version   Int
  title     String    @db.VarChar(200)
  content   String    @db.LongText
  authorId  String?
  createdAt DateTime  @default(now())

  @@unique([docId, version])
  @@index([docId])
}


// ---------------- Sheet (lightweight spreadsheet) ----------------

enum SheetStatus {
  ACTIVE
  ARCHIVED
}

model Sheet {
  id          String      @id @default(cuid())
  workspaceId String
  name        String      @db.VarChar(160)
  description String?     @db.VarChar(500)
  status      SheetStatus @default(ACTIVE)
  rowCount    Int         @default(50)
  colCount    Int         @default(10)
  ownerId     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cells       SheetCell[]

  @@index([workspaceId, status])
}

model SheetCell {
  id        String   @id @default(cuid())
  sheetId   String
  row       Int
  col       Int
  value     String?  @db.Text
  formula   String?  @db.VarChar(500)
  updatedAt DateTime @updatedAt
  sheet     Sheet    @relation(fields: [sheetId], references: [id], onDelete: Cascade)

  @@unique([sheetId, row, col])
  @@index([sheetId])
}

// ---------------- Slides (presentations) ----------------

enum PresentationStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SlideLayout {
  TITLE
  CONTENT
