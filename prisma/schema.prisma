model Booking {
  id            String        @id @default(cuid())
  workspaceId   String
  bookingTypeId String
  hostId        String
  publicId      String        @unique @default(cuid())
  attendeeName  String
  attendeeEmail String
  attendeePhone String?
  status        BookingStatus @default(SCHEDULED)
  startsAt      DateTime
  endsAt        DateTime
