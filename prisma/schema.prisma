enum RoadmapItemStatus {
  PLANNED
  IN_PROGRESS
  SHIPPED
}

model RoadmapItem {
  id           String            @id @default(cuid())
  workspaceId  String
  title        String            @db.VarChar(200)
  description  String?           @db.Text
  category     String?           @db.VarChar(80)
