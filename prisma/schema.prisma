// ---------------- DataPrep ----------------

enum DataPrepDatasetStatus {
  DRAFT
  READY
  RUNNING
  FAILED
}

enum DataPrepRuleKind {
  TRIM
  LOWERCASE
  UPPERCASE
  REMOVE_DUPLICATES
  FILL_MISSING
  REPLACE
  DROP_COLUMN
  RENAME_COLUMN
}

model DataPrepDataset {
  id          String                @id @default(cuid())
  workspaceId String
  name        String                @db.VarChar(160)
  description String?               @db.VarChar(500)
  sourceType  String                @default("csv") @db.VarChar(40)
  sourceConfig Json?
  rowCount    Int                   @default(0)
  columnCount Int                   @default(0)
  status      DataPrepDatasetStatus @default(DRAFT)
  createdById String
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  rules       DataPrepRule[]
  runs        DataPrepRun[]

  @@unique([workspaceId, name])
  @@index([workspaceId, status])
}

model DataPrepRule {
  id        String           @id @default(cuid())
  datasetId String
  position  Int              @default(0)
  kind      DataPrepRuleKind
  column    String?          @db.VarChar(120)
  config    Json?
  createdAt DateTime         @default(now())
  dataset   DataPrepDataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, position])
}

model DataPrepRun {
  id          String                @id @default(cuid())
  datasetId   String
  status      DataPrepDatasetStatus @default(RUNNING)
  rowsBefore  Int                   @default(0)
  rowsAfter   Int                   @default(0)
  rulesApplied Int                  @default(0)
  startedAt   DateTime              @default(now())
  finishedAt  DateTime?
  error       String?               @db.VarChar(1000)
  dataset     DataPrepDataset       @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([datasetId, startedAt])
}

// ---------------- Catalyst (serverless functions) ----------------

enum CatalystFunctionStatus {
  DRAFT
  ACTIVE
  DISABLED
}

enum CatalystRuntime {
  NODE_18
  NODE_20
  PYTHON_311
}

enum CatalystInvocationStatus {
  SUCCESS
  ERROR
  TIMEOUT
}

model CatalystFunction {
  id          String                 @id @default(cuid())
  workspaceId String
  name        String                 @db.VarChar(160)
  slug        String                 @db.VarChar(80)
  description String?                @db.VarChar(500)
  runtime     CatalystRuntime        @default(NODE_20)
  handler     String                 @default("index.handler") @db.VarChar(120)
  code        String                 @db.LongText
  status      CatalystFunctionStatus @default(DRAFT)
  timeoutMs   Int                    @default(30000)
  memoryMb    Int                    @default(128)
  invokeCount Int                    @default(0)
  errorCount  Int                    @default(0)
  lastInvokedAt DateTime?
  createdById String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  invocations CatalystInvocation[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
}

model CatalystInvocation {
  id         String                   @id @default(cuid())
  functionId String
  status     CatalystInvocationStatus
  durationMs Int                      @default(0)
  input      Json?
  output     Json?
  error      String?                  @db.VarChar(2000)
  log        String?                  @db.Text
  startedAt  DateTime                 @default(now())
  function   CatalystFunction         @relation(fields: [functionId], references: [id], onDelete: Cascade)

  @@index([functionId, startedAt])
}

// ---------------- Assist (remote support sessions) ----------------

enum AssistSessionStatus {
