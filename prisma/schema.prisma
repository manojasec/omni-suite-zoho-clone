  PART_TIME
  CONTRACT
  INTERN
  TEMPORARY
}

enum CandidateStatus {
  ACTIVE
  ARCHIVED
}

enum ApplicationStage {
  APPLIED
  SCREEN
  INTERVIEW
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum InterviewKind {
  PHONE
  VIDEO
  ONSITE
  TECHNICAL
  PANEL
}

enum InterviewOutcome {
  PENDING
  PASS
  FAIL
  NO_SHOW
}

model JobOpening {
