// ---------------- Status Page (public uptime) ----------------

enum StatusComponentState {
  OPERATIONAL
  DEGRADED
  PARTIAL_OUTAGE
  MAJOR_OUTAGE
  MAINTENANCE
}

enum StatusIncidentState {
  INVESTIGATING
  IDENTIFIED
  MONITORING
  RESOLVED
}

enum StatusIncidentImpact {
  NONE
  MINOR
  MAJOR
  CRITICAL
}

model StatusComponent {
  id          String               @id @default(cuid())
  workspaceId String
  name        String               @db.VarChar(120)
  description String?              @db.VarChar(500)
  state       StatusComponentState @default(OPERATIONAL)
  position    Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  workspace   Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, position])
}

model StatusIncident {
  id          String                 @id @default(cuid())
  workspaceId String
  title       String                 @db.VarChar(200)
  state       StatusIncidentState    @default(INVESTIGATING)
  impact      StatusIncidentImpact   @default(MINOR)
  startedAt   DateTime               @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  workspace   Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  updates     StatusIncidentUpdate[]

  @@index([workspaceId, startedAt])
  @@index([workspaceId, state])
}

model StatusIncidentUpdate {
  id         String              @id @default(cuid())
  incidentId String
  state      StatusIncidentState
  body       String              @db.Text
  createdAt  DateTime            @default(now())
  incident   StatusIncident      @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
}

