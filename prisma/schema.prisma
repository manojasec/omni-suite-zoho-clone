model RoadmapVote {
  id          String   @id @default(cuid())
  workspaceId String
  itemId      String
  voterEmail  String   @db.VarChar(160)
  createdAt   DateTime @default(now())

  workspace Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item      RoadmapItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, voterEmail])
  @@index([workspaceId])
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

model Quote {
  id           String          @id @default(cuid())
  workspaceId  String
  number       String          @db.VarChar(40)
  customerId   String
  dealId       String?
  status       QuoteStatus     @default(DRAFT)
  issueDate    DateTime        @default(now())
  expiresAt    DateTime?
  currency     String          @default("USD") @db.VarChar(8)
  subtotal     Decimal         @default(0) @db.Decimal(14, 2)
  tax          Decimal         @default(0) @db.Decimal(14, 2)
  total        Decimal         @default(0) @db.Decimal(14, 2)
  notes        String?         @db.Text
  invoiceId    String?
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  convertedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer         @relation(fields: [customerId], references: [id])
  deal      Deal?            @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lineItems QuoteLineItem[]

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
  @@index([workspaceId, customerId])
}

model QuoteLineItem {
  id          String  @id @default(cuid())
  quoteId     String
  description String  @db.VarChar(500)
  qty         Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @default(0) @db.Decimal(14, 2)
  taxPercent  Decimal @default(0) @db.Decimal(5, 2)
  amount      Decimal @default(0) @db.Decimal(14, 2)
  position    Int     @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model PortalAccess {
  id          String    @id @default(cuid())
  workspaceId String
  customerId  String
  token       String    @unique @db.VarChar(80)
  label       String?   @db.VarChar(120)
  expiresAt   DateTime?
  revokedAt   DateTime?
  lastUsedAt  DateTime?
  useCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([workspaceId, customerId])
}

enum GoalStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  ARCHIVED
}

enum KeyResultUnit {
  PERCENT
  NUMBER
  CURRENCY
  BOOLEAN
}

model Goal {
  id          String      @id @default(cuid())
  workspaceId String
  parentId    String?
  ownerId     String?
  title       String      @db.VarChar(200)
  description String?     @db.Text
  status      GoalStatus  @default(ON_TRACK)
  startDate   DateTime?
  dueDate     DateTime?
  progress    Decimal     @default(0) @db.Decimal(6, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  parent      Goal?       @relation("GoalTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Goal[]      @relation("GoalTree")
  keyResults  KeyResult[]

  @@index([workspaceId, status])
  @@index([workspaceId, ownerId])
  @@index([parentId])
}

model KeyResult {
  id           String        @id @default(cuid())
  goalId       String
  title        String        @db.VarChar(200)
  unit         KeyResultUnit @default(PERCENT)
  startValue   Decimal       @default(0) @db.Decimal(14, 2)
  targetValue  Decimal       @default(100) @db.Decimal(14, 2)
  currentValue Decimal       @default(0) @db.Decimal(14, 2)
  position     Int           @default(0)
  goal         Goal          @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
}

model TaxRate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @db.VarChar(120)
  rate        Decimal  @default(0) @db.Decimal(6, 3)
  region      String?  @db.VarChar(80)
  isInclusive Boolean  @default(false)
  isDefault   Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([workspaceId, name])
  @@index([workspaceId, isArchived])
}

model TwoFactorRecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @db.VarChar(120)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

model ApprovalPolicy {
  id            String            @id @default(cuid())
  workspaceId   String
  name          String            @db.VarChar(120)
  resource      String            @db.VarChar(60)
  threshold     Decimal?          @db.Decimal(14, 2)
  approverIds   String            @db.Text
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  requests      ApprovalRequest[]

  @@index([workspaceId, resource])
}

model ApprovalRequest {
  id          String                @id @default(cuid())
  workspaceId String
  policyId    String?
  resource    String                @db.VarChar(60)
  resourceId  String                @db.VarChar(40)
  requesterId String
  status      ApprovalRequestStatus @default(PENDING)
  reason      String?               @db.Text
  amount      Decimal?              @db.Decimal(14, 2)
  decidedById String?
  decidedAt   DateTime?
  decisionNote String?              @db.Text
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  policy      ApprovalPolicy?       @relation(fields: [policyId], references: [id], onDelete: SetNull)
  decisions   ApprovalDecisionLog[]

