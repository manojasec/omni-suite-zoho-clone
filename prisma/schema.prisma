// ---------------- M59 Meetings/Webinar ----------------

enum MeetingKind {
  MEETING
  WEBINAR
}
enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}
enum MeetingAttendeeRole {
  HOST
  PRESENTER
  ATTENDEE
}

model Meeting {
  id            String        @id @default(cuid())
  workspaceId   String
  hostId        String
  kind          MeetingKind   @default(MEETING)
  title         String        @db.VarChar(200)
  description   String?       @db.VarChar(2000)
  scheduledAt   DateTime
  durationMin   Int           @default(30)
  joinCode      String        @unique @db.VarChar(16)
  status        MeetingStatus @default(SCHEDULED)
  recordingUrl  String?       @db.VarChar(500)
  attendeeLimit Int           @default(100)
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  attendees     MeetingAttendee[]
  messages      MeetingMessage[]
  @@index([workspaceId, status, scheduledAt])
  @@index([workspaceId, hostId])
}

model MeetingAttendee {
  id        String              @id @default(cuid())
  meetingId String
  userId    String?
  name      String              @db.VarChar(160)
  email     String?             @db.VarChar(190)
  role      MeetingAttendeeRole @default(ATTENDEE)
  joinedAt  DateTime?
  leftAt    DateTime?
  meeting   Meeting             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId])
}

model MeetingMessage {
  id        String   @id @default(cuid())
  meetingId String
  actorId   String?
  authorName String  @db.VarChar(160)
  body      String   @db.VarChar(2000)
  createdAt DateTime @default(now())
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  @@index([meetingId, createdAt])
}

// ---------------- M60 Cliq team chat ----------------

enum ChannelKind {
  PUBLIC
  PRIVATE
  DM
}
enum ChannelMemberRole {
  MEMBER
  ADMIN
}

model Channel {
  id           String      @id @default(cuid())
  workspaceId  String
  name         String      @db.VarChar(120)
  topic        String?     @db.VarChar(300)
  kind         ChannelKind @default(PUBLIC)
  createdById  String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  members      ChannelMember[]
  messages     ChannelMessage[]
  @@unique([workspaceId, name])
  @@index([workspaceId, kind])
}

model ChannelMember {
  id         String            @id @default(cuid())
  channelId  String
  userId     String
  role       ChannelMemberRole @default(MEMBER)
  joinedAt   DateTime          @default(now())
  lastReadAt DateTime?
  channel    Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  @@unique([channelId, userId])
  @@index([userId])
}

model ChannelMessage {
  id        String   @id @default(cuid())
  channelId String
  authorId  String
  body      String   @db.VarChar(4000)
  parentId  String?
  createdAt DateTime @default(now())
  editedAt  DateTime?
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  @@index([channelId, createdAt])
  @@index([parentId])
}

// ---------------- M61 TeamInbox ----------------

enum SharedThreadStatus {
  OPEN
  PENDING
  CLOSED
}
enum SharedMessageDirection {
  IN
  OUT
  NOTE
}

model SharedInbox {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @db.VarChar(160)
  address     String   @db.VarChar(190)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     SharedInboxMember[]
  threads     SharedThread[]
  @@unique([workspaceId, address])
  @@index([workspaceId])
}

model SharedInboxMember {
  id       String      @id @default(cuid())
  inboxId  String
  userId   String
  joinedAt DateTime    @default(now())
  inbox    SharedInbox @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  @@unique([inboxId, userId])
  @@index([userId])
}

model SharedThread {
  id            String             @id @default(cuid())
  inboxId       String
  workspaceId   String
  subject       String             @db.VarChar(300)
  status        SharedThreadStatus @default(OPEN)
  assignedToId  String?
  fromName      String             @db.VarChar(160)
  fromEmail     String             @db.VarChar(190)
  lastMessageAt DateTime           @default(now())
  createdAt     DateTime           @default(now())
  inbox         SharedInbox        @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  messages      SharedMessage[]
  @@index([inboxId, status, lastMessageAt])
  @@index([workspaceId, assignedToId])
}

model SharedMessage {
  id        String                 @id @default(cuid())
  threadId  String
  direction SharedMessageDirection
  authorId  String?
  authorName String                @db.VarChar(160)
  body      String                 @db.Text
  createdAt DateTime               @default(now())
  thread    SharedThread           @relation(fields: [threadId], references: [id], onDelete: Cascade)
  @@index([threadId, createdAt])
}

// ---------------- M64 AI assistant (Zia) ----------------

enum AIMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model AIConversation {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  title       String   @db.VarChar(200)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  messages    AIMessage[]
  @@index([workspaceId, userId, updatedAt])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           AIMessageRole
  content        String         @db.Text
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@index([conversationId, createdAt])
}

// ---------------- M66 SAML / SCIM ----------------

enum SamlConnectionStatus {
  DRAFT
  ACTIVE
  DISABLED
}

model SamlConnection {
  id              String                @id @default(cuid())
  workspaceId     String                @unique
  name            String                @db.VarChar(160)
  idpEntityId     String                @db.VarChar(500)
  idpSsoUrl       String                @db.VarChar(500)
  idpCertificate  String                @db.Text
  spEntityId      String                @db.VarChar(500)
  status          SamlConnectionStatus  @default(DRAFT)
  createdById     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model ScimToken {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   @db.VarChar(160)
  tokenHash   String   @unique @db.VarChar(190)
  prefix      String   @db.VarChar(16)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdById String
  createdAt   DateTime @default(now())
  @@index([workspaceId, revokedAt])
}
