  ACTIVE
  ENDED
  CANCELLED
}

enum AssistEventKind {
  CREATED
  JOINED
  LEFT
  CHAT
  CONTROL_GRANTED
  CONTROL_RELEASED
  FILE_TRANSFER
  ENDED
