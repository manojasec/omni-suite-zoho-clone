// ===== Module 14: Subscriptions (recurring billing) =====

enum BillingInterval {
  WEEK
  MONTH
  QUARTER
  YEAR
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELED
  EXPIRED
}

enum SubscriptionInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model SubscriptionPlan {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name           String   @db.VarChar(120)
  code           String   @db.VarChar(60)
  description    String?  @db.Text
  amount         Decimal  @db.Decimal(14, 2)
  currency       String   @db.Char(3)
  interval       BillingInterval @default(MONTH)
  intervalCount  Int      @default(1)
  trialDays      Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  subscriptions  Subscription[]

  @@unique([workspaceId, code])
  @@index([workspaceId, active])
}

model Subscription {
  id              String   @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  customerName    String   @db.VarChar(160)
  customerEmail   String   @db.VarChar(160)
  status          SubscriptionStatus @default(TRIALING)
  quantity        Int      @default(1)
  startedAt       DateTime
  trialEndsAt     DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt      DateTime?
  cancelAtPeriodEnd  Boolean @default(false)
  notes           String?  @db.Text
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invoices        SubscriptionInvoice[]

  @@index([workspaceId, status])
  @@index([workspaceId, currentPeriodEnd])
  @@index([planId])
}

model SubscriptionInvoice {
  id             String   @id @default(cuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  number         String   @db.VarChar(40)
  status         SubscriptionInvoiceStatus @default(DRAFT)
  amount         Decimal  @db.Decimal(14, 2)
  currency       String   @db.Char(3)
  periodStart    DateTime
  periodEnd      DateTime
  issuedAt       DateTime @default(now())
  paidAt         DateTime?
  dueAt          DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([workspaceId, number])
  @@index([workspaceId, status])
  @@index([subscriptionId])
}

enum WidgetKind {
  KPI
  BAR
  LINE
  PIE
  TABLE
}

enum WidgetSource {
  DEAL
  INVOICE
  CONTACT
  TICKET
  TASK
  PROJECT
  EXPENSE
  SUBSCRIPTION
  SUBSCRIPTION_INVOICE
  CAMPAIGN
}

enum WidgetMetric {
  COUNT
  SUM
  AVG
}

model Dashboard {
