# --- Database (MySQL 8.0+) ---
DATABASE_URL="mysql://root:root@localhost:3306/omnisuite"

# --- Auth.js (NextAuth v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production-please-use-a-strong-secret"
AUTH_URL="http://localhost:3000"

# --- Optional OAuth providers ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Stripe (subscription billing) ---
# Leave blank to disable Stripe; the billing page will show a clear notice.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Map plan keys → Stripe Price IDs (created in Stripe dashboard).
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PROFESSIONAL=""
STRIPE_PRICE_ENTERPRISE=""

# --- Vault (password manager) ---
# Generate with: openssl rand -base64 32
VAULT_ENCRYPTION_KEY="change-me-32-byte-base64-key-for-aes-gcm"
